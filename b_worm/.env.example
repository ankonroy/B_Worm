# .env - REAL CREDENTIALS - NEVER COMMIT THIS FILE!

# Render PostgreSQL Database Credentials (from your dashboard)
DB_URL=jdbc:postgresql://YOUR_RENDER_HOST:5432/YOUR_DATABASE_NAME
DB_USERNAME=YOUR_USERNAME_FROM_RENDER
DB_PASSWORD=YOUR_PASSWORD_FROM_RENDER

# Optional: Server port (default is 8080)
PORT=8080

# Optional: JPA settings if you want to override
# JPA_DDL_AUTO=update
# JPA_SHOW_SQL=true